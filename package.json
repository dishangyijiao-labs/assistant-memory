{
  "name": "assistmem",
  "version": "0.1.0",
  "description": "Local indexer and keyword search for Cursor IDE, Copilot (VS Code), Cursor/Claude Code/Codex/Gemini CLI. No login.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "assistmem": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npx tsc && cp src/storage/schema.sql dist/storage/",
    "postbuild": "node -e \"const fs=require('fs');try{fs.chmodSync('dist/index.js',0o755);}catch(e){if(e.code!=='ENOENT')throw e;}\"",
    "start": "node dist/index.js",
    "index": "node dist/index.js index",
    "search": "node dist/index.js search",
    "serve": "node dist/index.js serve",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "desktop:prepare": "mkdir -p src-tauri/resources && rm -rf src-tauri/resources/dist && cp -R dist src-tauri/resources/dist",
    "desktop:dev": "npx @tauri-apps/cli@latest dev",
    "desktop:build": "npx @tauri-apps/cli@latest build",
    "desktop:check": "cargo check --manifest-path src-tauri/Cargo.toml"
  },
  "keywords": [
    "cursor",
    "copilot",
    "claude-code",
    "codex",
    "gemini",
    "chat-history",
    "full-text-search",
    "local"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dishangyijiao/assistmem.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "^11.6.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
